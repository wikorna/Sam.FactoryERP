{
  "schemaKey": "PurchaseOrder",
  "schemaVersion": "v1",
  "fileType": "PurchaseOrder",
  "displayName": "SAP MCP Purchase Order",
  "filenamePrefixPattern": "^[Pp]",
  "delimiter": ",",
  "hasHeaderRow": true,
  "hasSegmentMarkers": true,
  "headerRowMarker": "H1",
  "segmentMarkerColumn": 0,
  "skipLines": 0,
  "metadataRowMarkers": ["S1", "S2", "S3"],
  "metadataFields": {
    "S1": ["RohsNotice", "TransmissionDate", "TransmissionDateValue", "TransmissionTime", "TransmissionTimeValue"],
    "S2": ["FileLabel", "NumberOfRecord", "SupplierCode", "SupplierName", "ContactName", "ManagerName"],
    "S3": ["FileName", "NumberOfRecord", "SupplierCode", "SupplierName", "ContactName", "ManagerName"]
  },
  "requiredHeaders": [
    "PO Status",
    "PO No.",
    "PO Item",
    "Item No.",
    "Description",
    "Due Qty",
    "UM",
    "Due Date",
    "Unit Price",
    "Amount",
    "Currency"
  ],
  "optionalHeaders": [
    "BOI Name",
    "Type of Parts",
    "Production Month",
    "Production Lot",
    "Delivery Spot",
    "PO Date",
    "Delivery Type",
    "PO Comment2",
    "Ship By",
    "Ship To",
    "Terms of Trade",
    "Payment term",
    "Incharge Name",
    "Last Status",
    "Changes Note",
    "Old value",
    "New value"
  ],
  "headerAliases": {
    "PO No": "PO No.",
    "Item No": "Item No.",
    "DueQty": "Due Qty",
    "Due Quantity": "Due Qty",
    "Qty": "Due Qty",
    "UoM": "UM",
    "UOM": "UM",
    "Unit of Measure": "UM",
    "DueDate": "Due Date",
    "UnitPrice": "Unit Price",
    "POStatus": "PO Status",
    "PONo": "PO No.",
    "POItem": "PO Item",
    "ItemNo": "Item No."
  },
  "extractRules": {
    "documentNo": { "source": "filename", "stripExtension": true },
    "supplierCode": { "source": "metadata", "marker": "S3", "fieldIndex": 2 },
    "supplierName": { "source": "metadata", "marker": "S3", "fieldIndex": 3 },
    "transmissionDate": { "source": "metadata", "marker": "S1", "fieldIndex": 2 },
    "transmissionTime": { "source": "metadata", "marker": "S1", "fieldIndex": 4 }
  }
}
