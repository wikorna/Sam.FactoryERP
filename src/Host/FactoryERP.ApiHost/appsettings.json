{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "MassTransit": "Information"
    }
  },
  "AllowedHosts": "*",
  "Cache": {
    "DefaultExpirationMinutes": 60,
    "LocalCacheExpirationMinutes": 5,
    "MaximumPayloadBytes": 1048576,
    "MaximumKeyLength": 1024,
    "Redis": {
      "Enabled": false,
      "ConnectionString": "",
      "InstanceName": "FactoryERP:",
      "ConnectTimeoutMs": 5000,
      "SyncTimeoutMs": 5000,
      "AbortOnConnectFail": false
    }
  },
  "Jwt": {
    "Issuer": "https://factoryerp.local",
    "Audience": "factoryerp-api",
    "AccessTokenLifetimeMinutes": 15,
    "RefreshTokenLifetimeDays": 7,
    "ClockSkewSeconds": 30,
    "KeyDirectory": "Keys"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=FactoryDB;Username=wikorna;Password=20xcc94m",
    "EdiDatabase": "Host=localhost;Port=5432;Database=FactoryDB;Username=wikorna;Password=20xcc94m"
  },
  "LogPath": "Logs",
  "EnvironmentPrefix": "dev",
  "Email": {
    "Enabled": false,
    "FromName": "Sam.FactoryERP",
    "FromEmail": "noreply@factoryerp.local",
    "Smtp": {
      "Host": "localhost",
      "Port": 587,
      "UseStartTls": true,
      "TimeoutSeconds": 30
    }
  },
  "RabbitMQ": {
    "Enabled": true,
    "EnvironmentPrefix": "dev",
    "Connection": {
      "HostName": "localhost",
      "Port": 5672,
      "VirtualHost": "/",
      "UserName": "admin",
      "Password": "p@ssw0rd",
      "UseSsl": false
    }
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File",
      "Serilog.Enrichers.Environment",
      "Serilog.Enrichers.Thread"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "System": "Warning",
        "MassTransit": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Information"
      }
    },
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:HH:mm:ss} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/application-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "fileSizeLimitBytes": 268435456,
          "rollOnFileSizeLimit": true,
          "shared": true,
          "flushToDiskInterval": "00:00:01",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] (Thread:{ThreadId}) {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  }
}
